{
  "name": "@saju/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema=../../packages/api/prisma/schema.prisma && next build",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "verify": "pnpm typecheck && pnpm build",
    "deploy:prod": "pnpm dlx vercel --prod --yes"
  },
  "dependencies": {
    "@paddle/paddle-node-sdk": "^3.6.0",
    "@saju/api": "workspace:*",
    "@saju/engine-saju": "workspace:*",
    "@saju/shared": "workspace:*",
    "@tailwindcss/postcss": "^4.2.1",
    "lunar-typescript": "^1.8.6",
    "next": "15.5.12",
    "next-intl": "^4.8.3",
    "postcss": "^8.5.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@prisma/client": "^6",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.183.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.5.12",
    "prisma": "^6",
    "typescript": "^5.6.3"
  }
}
