# Required for LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Database (Supabase)
DATABASE_URL=

# Payments (Toss)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Email (Resend)
RESEND_API_KEY=

# Admin authentication
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=      # Required in production

# Paddle payments
PADDLE_API_KEY=             # Paddle vendor API key (server-side)
PADDLE_WEBHOOK_SECRET=      # Paddle webhook signing secret (from Paddle dashboard)
PADDLE_ENVIRONMENT=sandbox  # sandbox | production

# Cron authentication
CRON_SECRET=

# Public site URL (used for OG meta tags)
NEXT_PUBLIC_BASE_URL=https://fortunelab.store

# Kakao Share (Korean market)
NEXT_PUBLIC_KAKAO_JS_KEY=

# Optional model overrides
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.2
