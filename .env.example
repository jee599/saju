# ─── LLM (프로덕션 모델) ────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# 무료 분석: Haiku / 유료 분석: Sonnet
LLM_MODEL_FREE=claude-haiku-4-5-20251001
LLM_MODEL_PREMIUM=claude-sonnet-4-6

# LLM 비교 러너용 (pnpm compare:llm)
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODELS=claude-sonnet-4-6,claude-haiku-4-5-20251001
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODELS=gpt-5.3,gpt-4.1-mini
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODELS=gemini-2.0-flash

# ─── DB (Supabase PostgreSQL) ──────────────────────────
# Pooled URL (런타임용)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?schema=public&pgbouncer=true"
# Direct URL (마이그레이션용)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# ─── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── 결제 (Toss Payments — 한국) ───────────────────────
TOSS_CLIENT_KEY=your_toss_client_key_here
TOSS_SECRET_KEY=your_toss_secret_key_here

# ─── GA4 ───────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ─── 가격 A/B 테스트 (런칭 2~3주 후 활성화) ────────────
AB_TEST_ENABLED=false

# ─── Client API URLs ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_API_URL=http://localhost:3001
