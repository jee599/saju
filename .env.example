# Required for LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Database (Supabase)
DATABASE_URL=

# Payments (Toss)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Email (Resend)
RESEND_API_KEY=

# Admin authentication
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=      # Required in production

# Stripe payments (legacy / fallback)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=     # Required for webhook verification
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Paddle payments (primary provider)
PADDLE_API_KEY=             # Paddle vendor API key (server-side)
PADDLE_WEBHOOK_SECRET=      # Paddle webhook signing secret (from Paddle dashboard)
PADDLE_ENVIRONMENT=sandbox  # sandbox | production

# Runtime payment provider switch
# Set to "paddle" to route all non-KR checkout through Paddle.
# Set to "stripe" to force Stripe (or omit to use per-country default).
NEXT_PUBLIC_PAYMENT_PROVIDER=

# Cron authentication
CRON_SECRET=

# Optional model overrides
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.2
