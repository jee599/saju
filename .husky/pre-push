#!/bin/bash

# ── 스킵 조건 ──

LAST_MSG=$(git log -1 --pretty=%s)
if [[ "$LAST_MSG" == auto:* ]] || [[ "$LAST_MSG" == docs:* ]]; then
  exit 0
fi

CODE_CHANGES=$(git diff --name-only HEAD~1 HEAD 2>/dev/null \
  | grep -v '\.md$' | grep -v 'build-logs/' | grep -v '\.github/' | wc -l)
if [ "$CODE_CHANGES" -eq 0 ]; then
  exit 0
fi

# ── 빌드 로그 생성 ──

mkdir -p build-logs

gtimeout 60 /Users/jidong/.local/bin/claude -p \
  "최근 커밋을 분석하고 .claude/commands/build-log.md 형식대로 \
   build-logs/ 에 한국어/영어 빌드 로그를 생성해줘. STATUS.md도 갱신해줘." \
  || echo "⚠️ 빌드 로그 생성 스킵"

# ── 블로그 초안 생성 (커밋 5개 이상일 때만) ──

COMMIT_COUNT=$(git log --oneline -20 --no-merges | wc -l)
if [ "$COMMIT_COUNT" -ge 5 ]; then
  echo "📝 커밋 ${COMMIT_COUNT}개 감지. 블로그 초안 생성 중..."
  mkdir -p blog-drafts

  gtimeout 120 /Users/jidong/.local/bin/claude -p \
    "build-logs/ 의 최근 한국어 빌드 로그들과 git log를 바탕으로 \
     블로그 초안을 작성해줘. \
     문체: ~다 체. 첫 문장은 숫자/핵심 팩트. 6000자 이상. 불릿 금지. \
     구조: 문제→배경→딥다이브→결과. \
     DEV.to frontmatter 포함. published: false. tags 최대 4개 소문자. \
     앵커 태그(ai,webdev,beginners,productivity) 1개 이상. \
     한국어 초안만. \
     파일: blog-drafts/$(date +%Y-%m-%d)-draft-ko.md 로 저장." \
    || echo "⚠️ 블로그 초안 생성 스킵"
fi

# ── 생성된 파일 커밋 ──

CHANGED=""
[ -n "$(git status build-logs/ --porcelain 2>/dev/null)" ] && CHANGED="build-logs/"
[ -n "$(git status STATUS.md --porcelain 2>/dev/null)" ] && CHANGED="$CHANGED STATUS.md"
[ -n "$(git status blog-drafts/ --porcelain 2>/dev/null)" ] && CHANGED="$CHANGED blog-drafts/"

if [ -n "$CHANGED" ]; then
  git add $CHANGED
  git commit --no-verify -m "auto: build log"
fi

exit 0
